# .env.example
#
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.
# This file IS committed — it shows what variables are needed without exposing values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── PostHog (analytics — opt-in only) ────────────────────────────────────────
# https://app.posthog.com/project/settings
POSTHOG_API_KEY=phc_your-project-api-key
POSTHOG_HOST=https://app.posthog.com

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# https://sentry.io/settings/projects/ → Client Keys (DSN)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Firebase (push notifications) ────────────────────────────────────────────
# Download google-services.json (Android) and GoogleService-Info.plist (iOS)
# from Firebase Console → Project Settings → Your Apps
# Place them in:
#   android/app/google-services.json
#   ios/Runner/GoogleService-Info.plist
# No .env variables needed — Firebase uses the config files directly.

# ── RevenueCat (in-app purchases — added in V1.1) ────────────────────────────
# REVENUECAT_API_KEY=your-revenuecat-public-sdk-key
